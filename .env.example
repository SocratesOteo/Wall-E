# ── Required ──────────────────────────────────────────────────────────────────
# Wall-E brain model. Defaults to a strong open-model coding route via OpenRouter.
# You can also try:
#   WALL_E_MODEL=deepseek/deepseek-chat
#   WALL_E_MODEL=groq/moonshotai/kimi-k2-instruct-0905
WALL_E_MODEL=openrouter/qwen/qwen3-coder

# OpenRouter key — powers the default Wall-E brain model above
OPENROUTER_API_KEY=sk-or-...

# Optional provider keys if you switch WALL_E_MODEL to one of these providers
DEEPSEEK_API_KEY=
GROQ_API_KEY=
TOGETHERAI_API_KEY=

# Google API key — powers Gemini Flash in the TS and Go sub-agents
GOOGLE_API_KEY=AIza...

# ── Optional ──────────────────────────────────────────────────────────────────
# Absolute path to the project Wall-E will work on
# Defaults to the directory where you run Wall-E
WALL_E_PROJECT_ROOT=/path/to/your/project

# URLs for sub-agents (only needed if running them separately, not via Docker)
WALL_E_TS_AGENT_URL=http://localhost:8001
WALL_E_GO_AGENT_URL=http://localhost:8002

# Max seconds a shell command can run before Wall-E kills it
WALL_E_COMMAND_TIMEOUT=60
